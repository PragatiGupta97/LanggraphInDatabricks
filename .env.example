# Databricks Configuration
# Required for ChatDatabricks and WorkspaceClient

# Option 1: Databricks Token Authentication
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Option 2: OAuth Authentication
# DATABRICKS_CLIENT_ID=your_client_id
# DATABRICKS_CLIENT_SECRET=your_client_secret

# Model Configuration
# LLM_ENDPOINT=databricks-meta-llama-3-1-70b-instruct

# Alternative: Use OpenAI for local testing
# OPENAI_API_KEY=sk-...
# USE_OPENAI_FOR_LOCAL=true
